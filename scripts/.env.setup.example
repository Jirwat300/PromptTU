# Copy this file to scripts/.env.setup and fill in the 3 values below, then run:
#   bash scripts/vercel-env-backend.sh
#   bash scripts/vercel-env-frontend.sh
#
# This file is only read by the setup scripts. Do NOT commit scripts/.env.setup
# (it's already in .gitignore below).

# Public URL of the frontend Vercel project (no trailing slash).
# Examples:
#   FRONTEND_ORIGIN="https://prompttu.vercel.app"
#   FRONTEND_ORIGIN="https://www.prompttu.com"
# If you use multiple origins, separate with comma (no spaces):
#   FRONTEND_ORIGIN="https://prompttu.vercel.app,https://www.prompttu.com"
FRONTEND_ORIGIN=""

# Public URL of the backend Vercel project (no trailing slash).
# Example: BACKEND_URL="https://prompttu-backend.vercel.app"
BACKEND_URL=""

# Cloudflare Turnstile *site key* (public — starts with 0x...).
# This is DIFFERENT from TURNSTILE_SECRET_KEY you already set on the backend.
# Create a widget at https://dash.cloudflare.com -> Turnstile -> Add site.
TURNSTILE_SITE_KEY=""
